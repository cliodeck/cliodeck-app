{
  "name": "@cliodeck/lezer-pandoc-citations",
  "version": "0.1.0",
  "description": "Pandoc citation extension for the Lezer Markdown parser ([@key], clusters [@a; @b], locators, bare @key), for CodeMirror 6 and any @lezer/markdown consumer",
  "keywords": [
    "lezer",
    "lezer-markdown",
    "codemirror",
    "codemirror6",
    "markdown",
    "pandoc",
    "citations",
    "citeproc",
    "academic"
  ],
  "license": "MIT",
  "author": "Frédéric Clavert",
  "homepage": "https://github.com/cliodeck/cliodeck-app/tree/main/packages/lezer-pandoc-citations",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cliodeck/cliodeck-app.git",
    "directory": "packages/lezer-pandoc-citations"
  },
  "bugs": "https://github.com/cliodeck/cliodeck-app/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "npx tsup",
    "prepublishOnly": "npx tsup"
  },
  "peerDependencies": {
    "@lezer/highlight": "^1.0.0",
    "@lezer/markdown": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
