{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "ES2020",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "strict": false,
    "resolveJsonModule": true,
    "types": ["node", "better-sqlite3"],
    "paths": {
      "@/*": ["./src/*"],
      "@backend/*": ["./backend/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*",
    "backend/**/*",
    "scripts/cliodeck-cli.ts",
    "scripts/cli/**/*"
  ],
  "exclude": [
    "backend/__tests__/**/*",
    "src/main/**/__tests__/**/*",
    "scripts/__tests__/**/*"
  ]
}
